<!DOCTYPE html>
<html lang="en" class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>BEAM Characterization Lab</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/water.css@2/out/water.css" />
    <style>
      body { font-family: monospace; max-width: 1400px; margin: 0 auto; padding: 1rem; }
      nav { display: flex; gap: 1rem; padding: 0.5rem 0; border-bottom: 1px solid #ccc; }
      nav a { text-decoration: none; }
      nav a.active { font-weight: bold; }
      .metric-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1rem; }
      .metric-card { padding: 1rem; border-radius: 8px; border: 1px solid #333; background: #1e1e1e; color: #e0e0e0; }
      .metric-card.status-good { border-left: 4px solid #4caf50; background: #1b2e1b; }
      .metric-card.status-warn { border-left: 4px solid #ff9800; background: #2e2712; }
      .metric-card.status-danger { border-left: 4px solid #f44336; background: #2e1515; }
      .metric-label { font-size: 0.85rem; color: #aaa; margin-bottom: 0.25rem; text-transform: uppercase; letter-spacing: 0.5px; }
      .metric-value { font-size: 1.8rem; font-weight: 700; color: #fff; line-height: 1.2; }
      .metric-value small { font-size: 0.75rem; color: #888; margin-left: 6px; font-weight: 400; }
      .metric-trend { font-size: 0.75rem; color: #4caf50; margin-top: 0.25rem; }

      .scheduler-bars { display: flex; flex-direction: column; gap: 6px; }
      .scheduler-bar { display: flex; align-items: center; gap: 12px; }
      .scheduler-id { width: 50px; font-size: 0.8rem; color: #aaa; font-family: monospace; }
      .scheduler-bar-track { flex: 1; height: 24px; background: #333; border-radius: 12px; overflow: hidden; position: relative; border: 1px solid #444; }
      .scheduler-bar-fill { height: 100%; border-radius: 12px; transition: width 0.3s ease; }
      .scheduler-bar-fill.normal { background: linear-gradient(90deg, #81c784, #4caf50); box-shadow: 0 0 8px rgba(76, 175, 80, 0.4); }
      .scheduler-bar-fill.dirty-cpu { background: linear-gradient(90deg, #ffcc80, #ff9800); box-shadow: 0 0 8px rgba(255, 152, 0, 0.4); }
      .scheduler-bar-fill.dirty-io { background: linear-gradient(90deg, #90caf9, #2196f3); box-shadow: 0 0 8px rgba(33, 150, 243, 0.4); }
      .scheduler-bar-fill.blocked { background: linear-gradient(90deg, #ef5350, #e53935); box-shadow: 0 0 8px rgba(229, 57, 53, 0.4); }
      .scheduler-pct { width: 55px; text-align: right; font-size: 0.8rem; color: #ccc; font-family: monospace; }
      .assertion-pass { color: #4caf50; }
      .assertion-fail { color: #f44336; }
      .banner { padding: 1rem; background: #2e2712; border: 1px solid #ff9800; margin: 1rem 0; color: #fff; }
      .banner.danger { background: #2e1515; border-color: #f44336; }
      .chart-container { position: relative; height: 200px; margin: 1rem 0; }
      .language-mermaid { display: flex; justify-content: center; margin: 1rem 0; }
    </style>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
    <script src="https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.min.js"></script>
    <script>
      function runMermaid() {
        if (document.querySelector(".language-mermaid")) {
          mermaid.run({querySelector: ".language-mermaid"}).catch(() => {});
        }
      }
      document.addEventListener("DOMContentLoaded", runMermaid);
      document.addEventListener("phx:page-loading-stop", runMermaid);

      // Latency chart hook
      window.LatencyChartHook = {
        mounted() {
          const ctx = this.el.getContext('2d');
          this.chart = new Chart(ctx, {
            type: 'line',
            data: {
              labels: [],
              datasets: [
                {label: 'p50 (ms)', data: [], borderColor: '#4caf50', fill: false, tension: 0.2},
                {label: 'p99 (ms)', data: [], borderColor: '#ff9800', fill: false, tension: 0.2},
                {label: 'max (ms)', data: [], borderColor: '#f44336', fill: false, tension: 0.2}
              ]
            },
            options: {
              responsive: true,
              maintainAspectRatio: false,
              animation: {duration: 300},
              scales: {
                y: {beginAtZero: true, title: {display: true, text: 'ms'}},
                x: {display: false}
              },
              plugins: {legend: {display: true, position: 'top'}}
            }
          });

          // Listen for latency history updates from LiveView
          this.handleEvent("latency-history-update", ({history}) => {
            window.latencyHistory = history;
            if (this.chart) {
              const labels = history.map((_, i) => i);
              this.chart.data.labels = labels;
              this.chart.data.datasets[0].data = history.map(h => h.p50 ?? null);
              this.chart.data.datasets[1].data = history.map(h => h.p99 ?? null);
              this.chart.data.datasets[2].data = history.map(h => h.max ?? null);
              this.chart.update('none');
            }
          });
        }
      };
    </script>
  </head>
  <body class="h-full">
    <header>
      <h1>BEAM Characterization Lab</h1>
      <nav>
        <a href="/">Dashboard</a>
        <a href="/catalog">Catalog</a>
        <a href="/history">History</a>
        <a href="/docs">Docs</a>
      </nav>
    </header>
    <main>
      <%= @inner_content %>
    </main>
    <footer>
      <p><small>BEAM Characterization Lab — evidence over folklore</small></p>
    </footer>
  </body>
</html>
